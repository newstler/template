<%= form_with model: ConversationMessage.new,
              url: team_conversation_messages_path(current_team.slug, @conversation),
              multipart: true,
              data: { controller: "chat-input" } do |f| %>
  <div class="flex gap-2">
    <%= f.text_area :content,
                    rows: 1,
                    placeholder: t(".placeholder"),
                    data: { "chat-input-target": "textarea",
                            action: "keydown->chat-input#submit input->chat-input#resize" },
                    class: "flex-1 bg-dark-800 rounded p-2" %>
    <%= f.file_field :attachments, multiple: true,
                                    data: { "chat-input-target": "fileInput" } %>
    <%= f.submit t(".send"),
                 class: "px-4 py-2 bg-accent-500 text-white rounded" %>
  </div>
<% end %>
