<%#
  Rendered from both the show action (has current_user) and after_create_commit
  broadcast (no current_user). The partial must work in both contexts.
%>
<% visible = !defined?(current_user) || current_user.nil? ? true : message.visible_to?(current_user) %>
<% is_mine = defined?(current_user) && current_user.present? && message.user_id == current_user.id %>

<div id="<%= dom_id(message) %>" class="mb-6" data-user-id="<%= message.user_id %>">
  <% if is_mine %>
    <div class="flex justify-end">
      <div class="max-w-[85%]">
        <% if visible %>
          <div class="bg-dark-700 text-white rounded-2xl rounded-br-md px-4 py-3 shadow-lg shadow-black/20">
            <%= render "teams/conversations/message_attachments", message: message, doc_bg_class: "bg-dark-600 hover:bg-dark-500" %>
            <% if message.content.present? %>
              <div class="whitespace-pre-wrap"><%= message.body_for(current_user) %></div>
            <% end %>
          </div>
        <% else %>
          <div class="bg-dark-700 text-dark-300 italic rounded-2xl rounded-br-md px-4 py-3">
            <div class="text-sm"><%= t(".hidden_by_moderation") %></div>
          </div>
        <% end %>
        <div class="text-xs text-dark-500 text-right mt-1"><%= time_ago_in_words(message.created_at) %> <%= t("common.ago") %></div>
      </div>
    </div>
  <% else %>
    <div class="flex justify-start">
      <div class="max-w-[85%]">
        <% if visible %>
          <div class="bg-accent-600 text-white rounded-2xl rounded-tl-md px-4 py-3 shadow-lg shadow-black/20">
            <div class="text-xs opacity-75 mb-1"><%= message.user.name.presence || message.user.email %></div>
            <%= render "teams/conversations/message_attachments", message: message, doc_bg_class: "bg-accent-700 hover:bg-accent-800" %>
            <% if message.content.present? %>
              <div class="whitespace-pre-wrap"><%= message.body_for(current_user) %></div>
            <% end %>
          </div>
        <% else %>
          <div class="bg-dark-700 text-dark-300 italic rounded-2xl rounded-tl-md px-4 py-3">
            <div class="text-xs opacity-75 mb-1"><%= message.user.name.presence || message.user.email %></div>
            <div class="text-sm"><%= t(".hidden_by_moderation") %></div>
          </div>
        <% end %>
        <div class="text-xs text-dark-500 mt-1"><%= time_ago_in_words(message.created_at) %> <%= t("common.ago") %></div>
      </div>
    </div>
  <% end %>
</div>
