<% content_for :title, current_team.name %>

<div class="max-w-7xl mx-auto px-4 py-8">
  <header class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
    <div>
      <h1 class="text-3xl font-bold text-white"><%= current_team.name %></h1>
      <p class="text-dark-300 mt-1"><%= t(".subtitle") %></p>
    </div>

    <select data-controller="time-range"
            data-action="change->time-range#update"
            class="bg-dark-800 text-white text-sm px-3 py-2 rounded-lg border border-dark-700">
      <option value="7d"  <%= "selected" if params[:range] == "7d" %>><%= t(".ranges.7d") %></option>
      <option value="30d" <%= "selected" if params[:range].blank? || params[:range] == "30d" %>><%= t(".ranges.30d") %></option>
      <option value="90d" <%= "selected" if params[:range] == "90d" %>><%= t(".ranges.90d") %></option>
    </select>
  </header>

  <%= attention_items_strip(@attention_items) %>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <%= kpi_card label: t(".total_members"),
                 value: number_with_delimiter(@total_users),
                 icon: "users",
                 href: team_members_path(current_team.slug) %>
    <%= kpi_card label: t(".new_members"),
                 value: number_with_delimiter(@recent_users) %>
    <%= kpi_card label: t(".total_chats"),
                 value: number_with_delimiter(@total_chats),
                 icon: "chat",
                 href: team_chats_path(current_team.slug) %>
    <%= kpi_card label: t(".total_articles"),
                 value: number_with_delimiter(@total_articles),
                 icon: "file",
                 href: team_articles_path(current_team.slug) %>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <%= render "shared/chart_card", title: t(".chats_over_time"), subtitle: t(".chats_over_time_subtitle") do %>
      <%= line_chart @chats_timeline,
            colors: [ "oklch(65% 0.19 260)" ],
            library: { maintainAspectRatio: false },
            height: "260px" %>
    <% end %>

    <div class="p-4 bg-dark-800 rounded-lg">
      <h2 class="text-lg font-semibold text-white mb-4"><%= t(".welcome_heading", name: @user.name) %></h2>
      <p class="text-sm text-dark-300 mb-4"><%= t(".welcome_body") %></p>
      <dl class="space-y-2 text-sm">
        <div class="flex justify-between border-b border-dark-700 pb-2">
          <dt class="text-dark-400"><%= t(".email") %></dt>
          <dd class="text-dark-100"><%= @user.email %></dd>
        </div>
        <div class="flex justify-between border-b border-dark-700 pb-2">
          <dt class="text-dark-400"><%= t(".member_since") %></dt>
          <dd class="text-dark-100"><%= l(@user.created_at.to_date, format: :long) %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-dark-400"><%= t(".new_chats") %></dt>
          <dd class="text-dark-100"><%= number_with_delimiter(@recent_chats) %></dd>
        </div>
      </dl>
    </div>
  </div>
</div>
