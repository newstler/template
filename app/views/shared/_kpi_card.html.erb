<%# Locals: label:, value:, trend: (optional), icon: (optional), href: (optional), gradient: (optional) %>
<% wrapper_tag = local_assigns[:href].present? ? :a : :div %>
<% wrapper_attrs = local_assigns[:href].present? ? { href: href, class: "block" } : { class: "block" } %>
<% has_gradient = local_assigns[:gradient].present? %>

<%= content_tag(wrapper_tag, wrapper_attrs) do %>
  <div class="p-4 rounded-xl transition-shadow <%= has_gradient ? "bg-gradient-to-br #{gradient} shadow-lg" : "bg-dark-800 rounded-lg hover:bg-dark-700 transition-colors" %>">
    <div class="flex items-center justify-between mb-3">
      <% if local_assigns[:icon].present? %>
        <div class="p-2 <%= has_gradient ? "bg-white/20" : "bg-dark-700" %> rounded-lg">
          <%= inline_svg "icons/#{icon}.svg", class: "w-5 h-5 #{has_gradient ? "text-white" : "text-dark-300"}" %>
        </div>
      <% end %>
    </div>

    <div class="text-2xl font-bold <%= has_gradient ? "text-white" : "text-white" %>">
      <%= value %>
    </div>

    <p class="text-xs mt-1 <%= has_gradient ? "text-white/80" : "text-dark-300" %>"><%= label %></p>

    <% if local_assigns[:trend].present? %>
      <div class="mt-1 text-xs <%= trend >= 0 ? 'text-emerald-400' : 'text-red-400' %>">
        <%= trend_arrow(trend) %> <%= trend.abs %>%
      </div>
    <% end %>
  </div>
<% end %>
