<% content_for :title, t(".title") %>

<div>
  <header class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
    <div>
      <h1 class="text-3xl font-bold text-dark-50 mb-1"><%= t(".heading") %></h1>
      <p class="text-dark-400"><%= t(".subtitle") %></p>
    </div>

    <select data-controller="time-range"
            data-action="change->time-range#update"
            class="bg-dark-800 text-white text-sm px-3 py-2 rounded-lg border border-dark-700">
      <option value="7d"  <%= "selected" if params[:range] == "7d" %>><%= t(".ranges.7d") %></option>
      <option value="30d" <%= "selected" if params[:range].blank? || params[:range] == "30d" %>><%= t(".ranges.30d") %></option>
      <option value="90d" <%= "selected" if params[:range] == "90d" %>><%= t(".ranges.90d") %></option>
    </select>
  </header>

  <%# KPI grid %>
  <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-6 gap-4 mb-8">
    <div class="p-4 bg-gradient-to-br from-emerald-600/80 to-green-700/80 rounded-xl shadow-lg shadow-emerald-500/20">
      <div class="flex items-center justify-between mb-3">
        <div class="p-2 bg-white/20 rounded-lg">
          <%= inline_svg "icons/dollar.svg", class: "w-5 h-5 text-white" %>
        </div>
      </div>
      <p class="text-2xl font-bold text-white">$<%= number_with_precision(@metrics[:total_cost], precision: 2) %></p>
      <p class="text-xs text-white/80 mt-1"><%= t(".kpi.total_cost") %></p>
    </div>

    <%= kpi_card label: t(".kpi.total_users"), value: number_with_delimiter(@metrics[:total_users]), trend: nil, icon: "users", href: "/madmin/users" %>
    <%= kpi_card label: t(".kpi.total_teams"), value: number_with_delimiter(@metrics[:total_teams]), icon: "users", href: "/madmin/teams" %>
    <%= kpi_card label: t(".kpi.total_chats"), value: number_with_delimiter(@metrics[:total_chats]), icon: "chat", href: "/madmin/chats" %>
    <%= kpi_card label: t(".kpi.total_messages"), value: number_with_delimiter(@metrics[:total_messages]), icon: "messages", href: "/madmin/messages" %>
    <%= kpi_card label: t(".kpi.total_tokens"), value: number_with_delimiter(@metrics[:total_tokens]), icon: "lightning" %>
  </div>

  <%# Charts row %>
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
    <div class="lg:col-span-2">
      <%= render "shared/chart_card", title: t(".cost_over_time"), subtitle: t(".cost_over_time_subtitle") do %>
        <%= line_chart @cost_timeline,
              colors: [ "oklch(65% 0.19 150)" ],
              library: { maintainAspectRatio: false },
              height: "260px",
              prefix: "$",
              round: 4 %>
      <% end %>
    </div>

    <div class="card-bg p-4">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold text-dark-50"><%= t(".subscriptions.heading") %></h2>
        <%= link_to t(".view_all"), "/madmin/teams", class: "text-sm text-dark-400 hover:text-dark-200 font-medium" %>
      </div>
      <div class="space-y-3">
        <% sub_total = @subscription_stats.values.sum.to_f %>
        <% [
          [ t(".subscriptions.active"), @subscription_stats[:active], "bg-emerald-500", "text-emerald-400" ],
          [ t(".subscriptions.trialing"), @subscription_stats[:trialing], "bg-blue-500", "text-blue-400" ],
          [ t(".subscriptions.past_due"), @subscription_stats[:past_due], "bg-amber-500", "text-amber-400" ],
          [ t(".subscriptions.canceled"), @subscription_stats[:canceled], "bg-red-500", "text-red-400" ],
          [ t(".subscriptions.none"), @subscription_stats[:none], "bg-dark-500", "text-dark-400" ]
        ].each do |label, count, bar_color, text_color| %>
          <div>
            <div class="flex items-center justify-between mb-1">
              <span class="text-xs <%= text_color %>"><%= label %></span>
              <span class="text-xs font-medium text-dark-200"><%= count %></span>
            </div>
            <div class="w-full bg-dark-700 rounded-full h-1.5">
              <div class="<%= bar_color %> h-1.5 rounded-full transition-all"
                   style="width: <%= sub_total > 0 ? (count / sub_total * 100).round(1) : 0 %>%"></div>
            </div>
          </div>
        <% end %>
      </div>
      <div class="mt-5 pt-4 border-t border-dark-700">
        <div class="grid grid-cols-2 gap-3">
          <div>
            <p class="text-xs text-dark-400 mb-1"><%= t(".subscriptions.mrr") %></p>
            <% if @subscription_revenue[:available] %>
              <p class="text-lg font-bold text-emerald-400">$<%= number_with_precision(@subscription_revenue[:mrr], precision: 2) %></p>
            <% else %>
              <p class="text-xs text-dark-500"><%= t(".subscriptions.configure_stripe") %></p>
            <% end %>
          </div>
          <div>
            <p class="text-xs text-dark-400 mb-1"><%= t(".subscriptions.total_revenue") %></p>
            <% if @subscription_revenue[:available] %>
              <p class="text-lg font-bold text-dark-50">$<%= number_with_precision(@subscription_revenue[:total], precision: 2) %></p>
            <% else %>
              <p class="text-xs text-dark-500"><%= t(".subscriptions.configure_stripe") %></p>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%# Signup chart %>
  <div class="mb-8">
    <%= render "shared/chart_card", title: t(".signups_over_time"), subtitle: t(".signups_over_time_subtitle") do %>
      <%= line_chart @signup_timeline,
            colors: [ "oklch(65% 0.19 260)" ],
            library: { maintainAspectRatio: false },
            height: "220px" %>
    <% end %>
  </div>

  <%# Top tables %>
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="card-bg p-4">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold text-dark-50"><%= t(".top_teams") %></h2>
        <%= link_to t(".view_all"), "/madmin/teams", class: "text-sm text-dark-400 hover:text-dark-200 font-medium" %>
      </div>
      <div class="space-y-2">
        <% if @top_teams.any? %>
          <% @top_teams.each do |team| %>
            <%= link_to "/madmin/teams/#{team.slug}", class: "block p-3 bg-dark-800/50 rounded-lg hover:bg-dark-800 transition-colors" do %>
              <div class="flex items-center justify-between mb-1">
                <span class="font-medium text-dark-100 truncate"><%= team.name %></span>
                <span class="text-sm font-medium <%= team.ai_total_cost.to_f >= 0.10 ? "text-red-400" : "text-emerald-400" %>">
                  $<%= number_with_precision(team.ai_total_cost || 0, precision: 4) %>
                </span>
              </div>
              <div class="flex items-center gap-2 text-xs text-dark-500">
                <span><%= team.ai_chats_count %> <%= t(".chats") %></span>
                <span>&middot;</span>
                <span><%= team.ai_messages_count %> <%= t(".msgs") %></span>
              </div>
            <% end %>
          <% end %>
        <% else %>
          <div class="text-center py-8 text-dark-400"><%= t(".no_usage") %></div>
        <% end %>
      </div>
    </div>

    <div class="card-bg p-4">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold text-dark-50"><%= t(".top_users") %></h2>
        <%= link_to t(".view_all"), "/madmin/users", class: "text-sm text-dark-400 hover:text-dark-200 font-medium" %>
      </div>
      <div class="space-y-2">
        <% if @top_users.any? %>
          <% @top_users.each do |user| %>
            <%= link_to "/madmin/users/#{user.id}", class: "block p-3 bg-dark-800/50 rounded-lg hover:bg-dark-800 transition-colors" do %>
              <div class="flex items-center justify-between mb-1">
                <span class="font-medium text-dark-100 truncate"><%= user.name.presence || t(".unnamed") %></span>
                <span class="text-sm font-medium <%= user.ai_total_cost.to_f >= 0.10 ? "text-red-400" : "text-emerald-400" %>">
                  $<%= number_with_precision(user.ai_total_cost || 0, precision: 4) %>
                </span>
              </div>
              <div class="flex items-center gap-2 text-xs text-dark-500">
                <span class="truncate"><%= user.email %></span>
                <span>&middot;</span>
                <span><%= user.ai_chats_count %> <%= t(".chats") %></span>
              </div>
            <% end %>
          <% end %>
        <% else %>
          <div class="text-center py-8 text-dark-400"><%= t(".no_usage") %></div>
        <% end %>
      </div>
    </div>

    <div class="card-bg p-4">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold text-dark-50"><%= t(".recent_chats") %></h2>
        <%= link_to t(".view_all"), "/madmin/chats", class: "text-sm text-dark-400 hover:text-dark-200 font-medium" %>
      </div>
      <div class="space-y-2">
        <% if @recent_chats.any? %>
          <% @recent_chats.each do |chat| %>
            <%= link_to "/madmin/chats/#{chat.id}", class: "block p-3 bg-dark-800/50 rounded-lg hover:bg-dark-800 transition-colors" do %>
              <div class="flex items-center justify-between mb-1">
                <span class="text-sm font-medium text-dark-200 truncate"><%= chat.user&.name || chat.user&.email || t(".unknown") %></span>
                <span class="text-sm font-medium shrink-0 ml-2 <%= (chat.total_cost || 0) >= 0.10 ? "text-red-400" : "text-emerald-400" %>">
                  $<%= number_with_precision(chat.total_cost || 0, precision: 2) %>
                </span>
              </div>
              <div class="text-sm text-dark-400 truncate mb-1"><%= chat.messages.min_by(&:created_at)&.content&.truncate(70) || t(".empty_chat") %></div>
              <div class="flex items-center gap-2 text-xs text-dark-500">
                <span><%= chat.model&.name || t(".default_model") %></span>
                <span>&middot;</span>
                <span><%= chat.messages_count %> <%= t(".msgs") %></span>
                <span>&middot;</span>
                <span><%= time_ago_in_words(chat.created_at) %> <%= t(".ago") %></span>
              </div>
            <% end %>
          <% end %>
        <% else %>
          <div class="text-center py-8 text-dark-400"><%= t(".no_chats") %></div>
        <% end %>
      </div>
    </div>
  </div>
</div>
