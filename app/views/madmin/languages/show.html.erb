<%= content_for :title, resource.display_name(@record) %>

<header class="header">
  <h1>
    <%= link_to resource.friendly_name.pluralize, resource.index_path %>
    /
    <%= @record.name %>
  </h1>
  <div class="actions">
    <%= button_to main_app.toggle_madmin_language_path(@record), method: :patch, class: "btn btn-secondary" do %>
      <%= @record.enabled? ? "Disable" : "Enable" %>
    <% end %>
  </div>
</header>

<div class="card-bg p-6 mb-6">
  <div class="flex items-start gap-5">
    <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-sky-500 to-indigo-600 flex items-center justify-center shadow-lg shadow-sky-500/20">
      <span class="text-2xl font-bold text-white uppercase"><%= @record.code %></span>
    </div>
    <div class="flex-1">
      <h2 class="text-2xl font-bold text-dark-100"><%= @record.name %></h2>
      <p class="text-dark-400 mt-1"><%= @record.native_name %></p>
      <div class="flex items-center gap-2 mt-3">
        <% if @record.enabled? %>
          <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-emerald-500/15 text-emerald-400">
            <span class="w-1.5 h-1.5 bg-emerald-400 rounded-full mr-1.5"></span>Enabled
          </span>
        <% else %>
          <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-dark-700 text-dark-400">
            <span class="w-1.5 h-1.5 bg-dark-500 rounded-full mr-1.5"></span>Disabled
          </span>
        <% end %>
        <% if @record.english? %>
          <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-blue-500/15 text-blue-400">Required</span>
        <% end %>
      </div>
    </div>
  </div>
</div>

<% team_langs = @record.team_languages.includes(:team) %>
<% active_count = team_langs.count(&:active?) %>
<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
  <div class="card-bg p-5">
    <div class="text-dark-500 text-sm mb-1">Teams Using This Language</div>
    <div class="text-3xl font-bold text-dark-100"><%= team_langs.size %></div>
  </div>
  <div class="card-bg p-5">
    <div class="text-dark-500 text-sm mb-1">Currently Active</div>
    <div class="text-3xl font-bold text-emerald-400"><%= active_count %></div>
  </div>
  <div class="card-bg p-5">
    <div class="text-dark-500 text-sm mb-1">Created</div>
    <div class="text-lg font-bold text-dark-100"><%= @record.created_at.strftime("%-d %b %Y") %></div>
    <div class="text-xs text-dark-500 mt-1"><%= time_ago_in_words(@record.created_at) %> ago</div>
  </div>
</div>

<div class="card-bg overflow-hidden mb-6">
  <div class="px-5 py-4 border-b border-dark-700">
    <h2 class="text-lg font-semibold text-dark-100">Details</h2>
  </div>
  <div class="table-scroll">
    <table>
      <tbody>
        <tr>
          <th class="label">Code</th>
          <td class="font-mono text-sm uppercase"><%= @record.code %></td>
        </tr>
        <tr>
          <th class="label">English Name</th>
          <td><%= @record.name %></td>
        </tr>
        <tr>
          <th class="label">Native Name</th>
          <td><%= @record.native_name %></td>
        </tr>
        <tr>
          <th class="label">Enabled</th>
          <td>
            <% if @record.enabled? %>
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-emerald-500/15 text-emerald-400">Enabled</span>
            <% else %>
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-dark-700 text-dark-400">Disabled</span>
            <% end %>
          </td>
        </tr>
        <tr>
          <th class="label">Created</th>
          <td><%= @record.created_at.strftime("%-d %B %Y at %H:%M") %></td>
        </tr>
        <tr>
          <th class="label">Updated</th>
          <td><%= @record.updated_at.strftime("%-d %B %Y at %H:%M") %></td>
        </tr>
      </tbody>
    </table>
  </div>
</div>

<% if team_langs.any? %>
<div class="card-bg overflow-hidden">
  <div class="px-5 py-4 border-b border-dark-700">
    <h2 class="text-lg font-semibold text-dark-100">Teams (<%= team_langs.size %>)</h2>
  </div>
  <div class="table-scroll">
    <table>
      <thead>
        <tr>
          <th>Team</th>
          <th>Status</th>
          <th>Added</th>
        </tr>
      </thead>
      <tbody>
        <% team_langs.each do |tl| %>
          <tr>
            <td>
              <%= link_to "/madmin/teams/#{tl.team.slug}", class: "flex items-center gap-2 hover:underline" do %>
                <div class="w-6 h-6 rounded bg-dark-600 flex items-center justify-center text-[10px] font-bold text-dark-300">
                  <%= tl.team.name.first(2).upcase %>
                </div>
                <span><%= tl.team.name %></span>
              <% end %>
            </td>
            <td>
              <% if tl.active? %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-emerald-500/15 text-emerald-400">Active</span>
              <% else %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-dark-700 text-dark-400">Disabled</span>
              <% end %>
            </td>
            <td class="text-sm text-dark-400"><%= tl.created_at.strftime("%-d %b %Y") %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
<% end %>
