<%= content_for :title, @record.name || @record.email %>

<header class="header">
  <h1>
    <%= link_to resource_name_plural, resource.index_path %>
    /
    <%= @record.name || @record.email %>
  </h1>

  <div class="actions">
    <%= link_to t("madmin.common.edit"), resource.edit_path(@record), class: "btn btn-secondary" %>
  </div>
</header>

<div class="card-bg p-6 mb-6">
  <div class="flex items-start gap-6">
    <img src="https://www.gravatar.com/avatar/<%= Digest::MD5.hexdigest(@record.email.downcase.strip) %>?s=120&d=mp" class="w-24 h-24 rounded-full" alt="">
    <div class="flex-1">
      <h2 class="text-2xl font-bold text-dark-100"><%= @record.name || t(".unnamed_user") %></h2>
      <p class="text-dark-400 mt-1"><%= @record.email %></p>
      <p class="text-dark-500 text-sm mt-2"><%= t(".member_since", date: l(@record.created_at, format: :long)) %></p>
    </div>
  </div>
</div>

<% chats_count = @record.chats.size %>
<% total_messages = @record.chats.sum(&:messages_count) %>
<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
  <div class="card-bg p-5">
    <div class="text-dark-500 text-sm mb-1"><%= t(".total_chats") %></div>
    <div class="text-3xl font-bold text-dark-100"><%= chats_count %></div>
  </div>
  <div class="card-bg p-5">
    <div class="text-dark-500 text-sm mb-1"><%= t(".total_messages") %></div>
    <div class="text-3xl font-bold text-dark-100"><%= total_messages %></div>
  </div>
  <div class="card-bg p-5">
    <div class="text-dark-500 text-sm mb-1"><%= t(".total_cost") %></div>
    <div class="text-3xl font-bold <%= @record.total_cost >= 1.0 ? 'text-red-400' : 'text-emerald-400' %>"><%= format_cost(@record.total_cost || 0, precision: 4) %></div>
  </div>
</div>

<div class="card-bg overflow-hidden">
  <div class="px-5 py-4 border-b border-dark-700">
    <h2 class="text-lg font-semibold text-dark-100"><%= t(".details") %></h2>
  </div>
  <div class="table-scroll">
    <table>
      <tbody>
        <tr>
          <th class="label"><%= t(".id") %></th>
          <td class="font-mono text-sm"><%= @record.id %></td>
        </tr>
        <tr>
          <th class="label"><%= t(".email") %></th>
          <td><%= @record.email %></td>
        </tr>
        <tr>
          <th class="label"><%= t(".name") %></th>
          <td><%= @record.name || "-" %></td>
        </tr>
        <tr>
          <th class="label"><%= t(".created") %></th>
          <td><%= l(@record.created_at, format: :long) %></td>
        </tr>
        <tr>
          <th class="label"><%= t(".updated") %></th>
          <td><%= l(@record.updated_at, format: :long) %></td>
        </tr>
      </tbody>
    </table>
  </div>
</div>

<% memberships = @record.memberships %>
<% if memberships.any? %>
<div class="card-bg overflow-hidden mb-6">
  <div class="px-5 py-4 border-b border-dark-700">
    <h2 class="text-lg font-semibold text-dark-100"><%= t(".teams", count: memberships.size) %></h2>
  </div>
  <div class="table-scroll">
    <table>
      <thead>
        <tr>
          <th><%= t(".col_team") %></th>
          <th><%= t(".col_role") %></th>
          <th><%= t(".col_chats") %></th>
          <th><%= t(".col_joined") %></th>
        </tr>
      </thead>
      <tbody>
        <% memberships.each do |membership| %>
          <tr>
            <td>
              <%= link_to "/madmin/teams/#{membership.team.slug}" do %>
                <div class="font-medium"><%= membership.team.name %></div>
                <div class="text-xs text-dark-500"><%= membership.team.slug %></div>
              <% end %>
            </td>
            <td>
              <% role_class = case membership.role
                when "owner" then "bg-amber-500/15 text-amber-400"
                when "admin" then "bg-purple-500/15 text-purple-400"
                else "bg-dark-600 text-dark-300"
              end %>
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium <%= role_class %>">
                <%= membership.role.titleize %>
              </span>
            </td>
            <td><%= @record.chats.count { |c| c.team_id == membership.team_id } %></td>
            <td class="text-sm"><%= l(membership.created_at, format: :long) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
<% end %>

<% if chats_count > 0 %>
<% recent_chats = @record.chats.sort_by(&:created_at).reverse.first(5) %>
<div class="card-bg mt-6 overflow-hidden">
  <div class="px-5 py-4 border-b border-dark-700">
    <h2 class="text-lg font-semibold text-dark-100"><%= t(".recent_chats") %></h2>
  </div>
  <div class="table-scroll">
    <table>
      <thead>
        <tr>
          <th><%= t(".col_first_message") %></th>
          <th><%= t(".col_model") %></th>
          <th><%= t(".col_messages") %></th>
          <th><%= t(".col_cost") %></th>
          <th><%= t(".col_created") %></th>
        </tr>
      </thead>
      <tbody>
        <% recent_chats.each do |chat| %>
          <tr>
            <td class="max-w-xs">
              <%= link_to "/madmin/chats/#{chat.id}", class: "block truncate hover:underline" do %>
                <%= chat.messages.min_by(&:created_at)&.content&.truncate(60) || t(".empty_chat") %>
              <% end %>
            </td>
            <td><%= chat.model&.name || t(".default_model") %></td>
            <td><%= chat.messages_count %></td>
            <td class="<%= (chat.total_cost || 0) >= 0.10 ? 'text-red-400' : 'text-emerald-400' %>"><%= format_cost(chat.total_cost || 0, precision: 4) %></td>
            <td><%= l(chat.created_at, format: :long) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
  <% if chats_count > 5 %>
    <div class="px-5 py-3 border-t border-dark-700">
      <%= link_to t(".view_all_chats", count: chats_count), "/madmin/chats?q=#{@record.email}", class: "text-sm text-accent-400 hover:text-accent-300" %>
    </div>
  <% end %>
</div>
<% end %>
