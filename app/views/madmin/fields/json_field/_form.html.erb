<% val = field.value(record) %>
<%= form.text_area field.attribute_name,
    value: val ? JSON.pretty_generate(val) : "{}",
    rows: 10,
    class: "form-control font-mono text-sm",
    placeholder: t("madmin.common.json_placeholder") %>
<p class="text-xs text-gray-500 mt-1"><%= t("madmin.common.json_format_hint") %></p>
