<%= content_for :title, resource_name_plural %>

<header class="header">
  <h1><%= resource_name_plural %></h1>
  <% setting = Setting.instance %>
  <%= button_to main_app.toggle_articles_madmin_articles_path, method: :patch, class: "inline-flex items-center gap-2 px-3 py-1.5 rounded-lg text-sm font-medium transition-colors #{setting.articles_enabled? ? 'bg-emerald-500/15 text-emerald-400 hover:bg-emerald-500/25' : 'bg-dark-700 text-dark-400 hover:bg-dark-600'}" do %>
    <span class="w-2 h-2 rounded-full <%= setting.articles_enabled? ? 'bg-emerald-400' : 'bg-dark-500' %>"></span>
    <%= t(".articles") %> <%= setting.articles_enabled? ? t("madmin.common.status_on") : t("madmin.common.status_off") %>
  <% end %>
</header>

<div class="filters mb-4 p-4 card-bg">
  <%= form_with url: resource.index_path, method: :get, class: "flex gap-3 items-end flex-wrap" do |f| %>
    <div>
      <%= f.label :q, t("madmin.common.search"), class: "block text-sm font-medium text-dark-300 mb-1" %>
      <%= f.search_field :q, value: params[:q], placeholder: t(".search_placeholder"), class: "form-input" %>
    </div>

    <div>
      <%= f.label :team_id, t(".col_team"), class: "block text-sm font-medium text-dark-300 mb-1" %>
      <% teams = Team.order(:name).pluck(:name, :id) %>
      <%= f.select :team_id,
          options_for_select([[t(".all_teams"), ""]] + teams, params[:team_id]),
          {},
          class: "form-select" %>
    </div>

    <div class="flex gap-2">
      <%= f.submit t("madmin.common.filter"), class: "btn btn-primary" %>
      <% if params[:q].present? || params[:team_id].present? %>
        <%= link_to t("madmin.common.clear"), resource.index_path, class: "btn btn-secondary" %>
      <% end %>
    </div>
  <% end %>
</div>

<div class="table-scroll">
  <table>
    <thead>
      <tr>
        <th><%= sortable :title, t(".col_article") %></th>
        <th><%= sortable :team_name, t(".col_team") %></th>
        <th><%= sortable :author_name, t(".col_author") %></th>
        <th><%= sortable :created_at, t(".col_created") %></th>
      </tr>
    </thead>

    <tbody>
      <% @records.each do |record| %>
        <tr>
          <td class="max-w-md">
            <%= link_to resource.show_path(record), class: "block" do %>
              <div class="font-medium"><%= record.title.truncate(80) %></div>
            <% end %>
          </td>
          <td>
            <%= link_to "/madmin/teams/#{record.team.slug}", class: "inline-flex items-center gap-1.5 hover:underline" do %>
              <div class="w-5 h-5 rounded bg-dark-600 flex items-center justify-center text-[10px] font-bold text-dark-300">
                <%= record.team.name.first(2).upcase %>
              </div>
              <span class="text-sm"><%= record.team.name %></span>
            <% end %>
          </td>
          <td>
            <%= link_to "/madmin/users/#{record.user.id}", class: "flex items-center gap-2 hover:underline" do %>
              <img src="https://www.gravatar.com/avatar/<%= Digest::MD5.hexdigest(record.user.email.downcase.strip) %>?s=24&d=mp" class="w-6 h-6 rounded-full" alt="">
              <span class="text-sm"><%= record.user.name.presence || record.user.email %></span>
            <% end %>
          </td>
          <td class="text-sm"><%= l(record.created_at, format: :long) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<div class="pagination">
  <% if @pagy.respond_to?(:series_nav) %>
    <%== @pagy.series_nav if @pagy.last > 1 %>
    <%== @pagy.info_tag %>
  <% else %>
    <%== pagy_nav @pagy if @pagy.last > 1 %>
    <%== pagy_info @pagy %>
  <% end %>
</div>
