<% active_tab = params[:tab] == "providers" ? 1 : 0 %>

<div class="max-w-3xl mx-auto">
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-white"><%= t(".heading") %></h1>
  </div>

  <div data-controller="tabs" data-tabs-active-class="border-accent-500 text-dark-100" data-tabs-inactive-class="border-transparent text-dark-400 hover:text-dark-200">
    <div class="flex gap-0 border-b border-dark-700 mb-6">
      <button data-tabs-target="tab" data-action="click->tabs#select" data-index="0"
              class="px-5 py-3 text-sm font-medium border-b-2 transition-colors -mb-px <%= active_tab == 0 ? 'border-accent-500 text-dark-100' : 'border-transparent text-dark-400 hover:text-dark-200' %>">
        <%= t(".tab_system") %>
      </button>
      <button data-tabs-target="tab" data-action="click->tabs#select" data-index="1"
              class="px-5 py-3 text-sm font-medium border-b-2 transition-colors -mb-px <%= active_tab == 1 ? 'border-accent-500 text-dark-100' : 'border-transparent text-dark-400 hover:text-dark-200' %>">
        <%= t(".tab_providers") %>
      </button>
    </div>

    <%# System Tab — inline editing with autosave %>
    <div data-tabs-target="panel" class="<%= 'hidden' if active_tab != 0 %>">
      <%= form_with model: @setting, url: main_app.madmin_settings_path, method: :patch, data: { controller: "autosave" }, class: "space-y-6" do |form| %>
        <span data-autosave-target="status" class="hidden fixed top-4 right-4 z-50 px-3 py-1.5 bg-dark-700 text-dark-200 text-sm rounded-lg shadow-lg"></span>

        <%# Stripe %>
        <div class="card-bg p-6">
          <h2 class="text-xl font-semibold text-dark-100 mb-4"><%= t(".stripe") %></h2>
          <div class="space-y-4">
            <div>
              <%= form.label :stripe_secret_key, t(".stripe_secret_key"), class: "block text-sm font-medium text-dark-200 mb-2" %>
              <%= form.password_field :stripe_secret_key,
                value: @setting.stripe_secret_key,
                placeholder: t("madmin.providers.index.key_placeholder"),
                data: { action: "change->autosave#save" },
                class: "w-full px-4 py-3 border border-dark-600 bg-dark-800 text-dark-100 rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 focus:outline-none transition-all placeholder-dark-500 font-mono text-sm" %>
            </div>
            <div>
              <%= form.label :stripe_publishable_key, t(".stripe_publishable_key"), class: "block text-sm font-medium text-dark-200 mb-2" %>
              <%= form.text_field :stripe_publishable_key,
                placeholder: t("madmin.providers.index.key_placeholder"),
                data: { action: "change->autosave#save" },
                class: "w-full px-4 py-3 border border-dark-600 bg-dark-800 text-dark-100 rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 focus:outline-none transition-all placeholder-dark-500 font-mono text-sm" %>
            </div>
            <div>
              <%= form.label :stripe_webhook_secret, t(".stripe_webhook_secret"), class: "block text-sm font-medium text-dark-200 mb-2" %>
              <%= form.password_field :stripe_webhook_secret,
                value: @setting.stripe_webhook_secret,
                placeholder: t("madmin.providers.index.key_placeholder"),
                data: { action: "change->autosave#save" },
                class: "w-full px-4 py-3 border border-dark-600 bg-dark-800 text-dark-100 rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 focus:outline-none transition-all placeholder-dark-500 font-mono text-sm" %>
            </div>
            <div>
              <%= form.label :trial_days, t(".trial_days"), class: "block text-sm font-medium text-dark-200 mb-2" %>
              <%= form.number_field :trial_days,
                min: 0,
                data: { action: "change->autosave#save" },
                class: "w-full px-4 py-3 border border-dark-600 bg-dark-800 text-dark-100 rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 focus:outline-none transition-all text-sm" %>
            </div>
          </div>
        </div>

        <%# Currency %>
        <div class="card-bg p-6">
          <h2 class="text-xl font-semibold text-dark-100 mb-4"><%= t(".currency_heading") %></h2>
          <div>
            <%= form.label :currencylayer_api_key, t(".currencylayer_api_key"), class: "block text-sm font-medium text-dark-200 mb-2" %>
            <%= form.password_field :currencylayer_api_key,
              value: @setting.currencylayer_api_key,
              placeholder: t("madmin.providers.index.key_placeholder"),
              data: { action: "change->autosave#save" },
              class: "w-full px-4 py-3 border border-dark-600 bg-dark-800 text-dark-100 rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 focus:outline-none transition-all placeholder-dark-500 font-mono text-sm" %>
          </div>
        </div>

        <%# Litestream %>
        <div class="card-bg p-6">
          <h2 class="text-xl font-semibold text-dark-100 mb-2"><%= t(".litestream") %></h2>
          <p class="text-sm text-dark-500 mb-4"><%= t(".litestream_restart_note") %></p>
          <div class="space-y-4">
            <div>
              <%= form.label :litestream_replica_bucket, t(".litestream_replica_bucket"), class: "block text-sm font-medium text-dark-200 mb-2" %>
              <%= form.text_field :litestream_replica_bucket,
                placeholder: "my-bucket.s3.amazonaws.com",
                data: { action: "change->autosave#save" },
                class: "w-full px-4 py-3 border border-dark-600 bg-dark-800 text-dark-100 rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 focus:outline-none transition-all placeholder-dark-500 text-sm" %>
            </div>
            <div>
              <%= form.label :litestream_replica_key_id, t(".litestream_replica_key_id"), class: "block text-sm font-medium text-dark-200 mb-2" %>
              <%= form.password_field :litestream_replica_key_id,
                value: @setting.litestream_replica_key_id,
                placeholder: t("madmin.providers.index.key_placeholder"),
                data: { action: "change->autosave#save" },
                class: "w-full px-4 py-3 border border-dark-600 bg-dark-800 text-dark-100 rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 focus:outline-none transition-all placeholder-dark-500 font-mono text-sm" %>
            </div>
            <div>
              <%= form.label :litestream_replica_access_key, t(".litestream_replica_access_key"), class: "block text-sm font-medium text-dark-200 mb-2" %>
              <%= form.password_field :litestream_replica_access_key,
                value: @setting.litestream_replica_access_key,
                placeholder: t("madmin.providers.index.key_placeholder"),
                data: { action: "change->autosave#save" },
                class: "w-full px-4 py-3 border border-dark-600 bg-dark-800 text-dark-100 rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 focus:outline-none transition-all placeholder-dark-500 font-mono text-sm" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <%# AI Providers Tab — inline editing with autosave %>
    <div data-tabs-target="panel" class="<%= 'hidden' if active_tab != 1 %>">
      <%= form_with url: main_app.madmin_settings_path, method: :patch, data: { controller: "autosave" }, class: "space-y-6" do |form| %>
        <span data-autosave-target="status" class="hidden fixed top-4 right-4 z-50 px-3 py-1.5 bg-dark-700 text-dark-200 text-sm rounded-lg shadow-lg"></span>

        <% @providers.each do |provider, settings| %>
          <div class="card-bg p-6">
            <div class="flex items-center gap-3 mb-4">
              <h2 class="text-xl font-semibold text-dark-100"><%= t("madmin.providers.index.providers.#{provider}", default: provider.titleize) %></h2>
              <% if ProviderCredential.configured?(provider) %>
                <span class="w-2 h-2 bg-green-400 rounded-full"></span>
              <% end %>
            </div>
            <div class="space-y-4">
              <% settings.each do |setting| %>
                <% credential = @credentials[[provider, setting]] %>
                <% field_name = "providers[#{provider}][#{setting}]" %>
                <% field_id = "providers_#{provider}_#{setting}" %>
                <% is_secret = setting.end_with?("_key", "_secret", "_token") %>
                <div>
                  <%= label_tag field_id, t("madmin.providers.index.settings.#{setting}", default: setting.titleize), class: "block text-sm font-medium text-dark-200 mb-2" %>
                  <% if is_secret %>
                    <%= password_field_tag field_name, credential&.value,
                      id: field_id,
                      placeholder: t("madmin.providers.index.key_placeholder"),
                      data: { action: "change->autosave#save" },
                      class: "w-full px-4 py-3 border border-dark-600 bg-dark-800 text-dark-100 rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 focus:outline-none transition-all placeholder-dark-500 font-mono text-sm" %>
                  <% else %>
                    <%= text_field_tag field_name, credential&.value,
                      id: field_id,
                      placeholder: t("madmin.providers.index.placeholders.#{setting}", default: ""),
                      data: { action: "change->autosave#save" },
                      class: "w-full px-4 py-3 border border-dark-600 bg-dark-800 text-dark-100 rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 focus:outline-none transition-all placeholder-dark-500 text-sm" %>
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
