<%= content_for :title, resource.display_name(@record) %>

<header class="header">
  <h1>
    <%= link_to resource_name_plural, resource.index_path %>
    /
    <%= resource.display_name(@record) %>
  </h1>
</header>

<div class="card-bg p-6 mb-6">
  <div class="flex items-start gap-5">
    <img src="https://www.gravatar.com/avatar/<%= Digest::MD5.hexdigest(@record.user.email.downcase.strip) %>?s=80&d=mp" class="w-16 h-16 rounded-full" alt="">
    <div class="flex-1">
      <h2 class="text-2xl font-bold text-dark-100">
        <%= link_to @record.user.name.presence || @record.user.email, "/madmin/users/#{@record.user.id}", class: "hover:underline" %>
      </h2>
      <div class="flex items-center gap-3 mt-2">
        <% role_class = case @record.role
          when "owner" then "bg-amber-500/15 text-amber-400"
          when "admin" then "bg-purple-500/15 text-purple-400"
          else "bg-dark-600 text-dark-300"
        end %>
        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium <%= role_class %>">
          <%= @record.role.titleize %>
        </span>
        <span class="text-dark-500"><%= t(".in_team") %></span>
        <%= link_to @record.team.name, "/madmin/teams/#{@record.team.slug}", class: "text-dark-200 hover:underline font-medium" %>
      </div>
      <p class="text-dark-500 text-sm mt-2"><%= t(".member_since", date: l(@record.created_at, format: :long)) %></p>
    </div>
  </div>
</div>

<div class="card-bg overflow-hidden">
  <div class="px-5 py-4 border-b border-dark-700">
    <h2 class="text-lg font-semibold text-dark-100"><%= t(".details") %></h2>
  </div>
  <div class="table-scroll">
    <table>
      <tbody>
        <tr>
          <th class="label"><%= t(".label_id") %></th>
          <td class="font-mono text-sm"><%= @record.id %></td>
        </tr>
        <tr>
          <th class="label"><%= t(".label_user") %></th>
          <td>
            <%= link_to "/madmin/users/#{@record.user.id}", class: "flex items-center gap-2 hover:underline" do %>
              <img src="https://www.gravatar.com/avatar/<%= Digest::MD5.hexdigest(@record.user.email.downcase.strip) %>?s=24&d=mp" class="w-6 h-6 rounded-full" alt="">
              <span><%= @record.user.name.presence || @record.user.email %></span>
            <% end %>
          </td>
        </tr>
        <tr>
          <th class="label"><%= t(".label_email") %></th>
          <td><%= @record.user.email %></td>
        </tr>
        <tr>
          <th class="label"><%= t(".label_team") %></th>
          <td>
            <%= link_to @record.team.name, "/madmin/teams/#{@record.team.slug}", class: "hover:underline" %>
          </td>
        </tr>
        <tr>
          <th class="label"><%= t(".label_role") %></th>
          <td>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= role_class %>">
              <%= @record.role.titleize %>
            </span>
          </td>
        </tr>
        <% if @record.invited_by %>
        <tr>
          <th class="label"><%= t(".label_invited_by") %></th>
          <td>
            <%= link_to "/madmin/users/#{@record.invited_by.id}", class: "flex items-center gap-2 hover:underline" do %>
              <img src="https://www.gravatar.com/avatar/<%= Digest::MD5.hexdigest(@record.invited_by.email.downcase.strip) %>?s=24&d=mp" class="w-6 h-6 rounded-full" alt="">
              <span><%= @record.invited_by.name.presence || @record.invited_by.email %></span>
            <% end %>
          </td>
        </tr>
        <% end %>
        <tr>
          <th class="label"><%= t(".label_joined") %></th>
          <td><%= l(@record.created_at, format: :long) %></td>
        </tr>
        <tr>
          <th class="label"><%= t(".label_updated") %></th>
          <td><%= l(@record.updated_at, format: :long) %></td>
        </tr>
      </tbody>
    </table>
  </div>
</div>
