<%= content_for :title, resource.friendly_name.pluralize %>

<header class="header">
  <h1><%= resource.friendly_name.pluralize %></h1>
</header>

<div class="filters mb-4 p-4 card-bg">
  <%= form_with url: resource.index_path, method: :get, class: "flex gap-3 items-end flex-wrap" do |f| %>
    <div>
      <%= f.label :q, "Search", class: "block text-sm font-medium text-dark-300 mb-1" %>
      <%= f.search_field :q, value: params[:q], placeholder: "Search by user or team...", class: "form-input" %>
    </div>

    <div>
      <%= f.label :role, "Role", class: "block text-sm font-medium text-dark-300 mb-1" %>
      <%= f.select :role,
          options_for_select([["All roles", ""]] + Membership::ROLES.map { |r| [r.titleize, r] }, params[:role]),
          {},
          class: "form-select" %>
    </div>

    <div>
      <%= f.label :team_id, "Team", class: "block text-sm font-medium text-dark-300 mb-1" %>
      <% teams = Team.order(:name).pluck(:name, :id) %>
      <%= f.select :team_id,
          options_for_select([["All teams", ""]] + teams, params[:team_id]),
          {},
          class: "form-select" %>
    </div>

    <div class="flex gap-2">
      <%= f.submit "Filter", class: "btn btn-primary" %>
      <% if params[:q].present? || params[:role].present? || params[:team_id].present? %>
        <%= link_to "Clear", resource.index_path, class: "btn btn-secondary" %>
      <% end %>
    </div>
  <% end %>
</div>

<div class="table-scroll">
  <table>
    <thead>
      <tr>
        <th><%= sortable :user_name, "User" %></th>
        <th><%= sortable :team_name, "Team" %></th>
        <th><%= sortable :role, "Role" %></th>
        <th><%= sortable :created_at, "Joined" %></th>
      </tr>
    </thead>

    <tbody>
      <% @records.each do |record| %>
        <tr>
          <td>
            <%= link_to "/madmin/users/#{record.user.id}", class: "flex items-center gap-3" do %>
              <img src="https://www.gravatar.com/avatar/<%= Digest::MD5.hexdigest(record.user.email.downcase.strip) %>?s=32&d=mp" class="w-8 h-8 rounded-full" alt="">
              <div>
                <div class="font-medium"><%= record.user.name.presence || "Unnamed" %></div>
                <div class="text-xs text-dark-500"><%= record.user.email %></div>
              </div>
            <% end %>
          </td>
          <td>
            <%= link_to "/madmin/teams/#{record.team.slug}", class: "flex items-center gap-2 hover:underline" do %>
              <div class="w-7 h-7 rounded bg-dark-600 flex items-center justify-center text-xs font-bold text-dark-300">
                <%= record.team.name.first(2).upcase %>
              </div>
              <span><%= record.team.name %></span>
            <% end %>
          </td>
          <td>
            <% role_class = case record.role
              when "owner" then "bg-amber-500/15 text-amber-400"
              when "admin" then "bg-purple-500/15 text-purple-400"
              else "bg-dark-600 text-dark-300"
            end %>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= role_class %>">
              <%= record.role.titleize %>
            </span>
          </td>
          <td class="text-sm"><%= record.created_at.strftime("%-d %b %Y") %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<div class="pagination">
  <% if @pagy.respond_to?(:series_nav) %>
    <%== @pagy.series_nav if @pagy.last > 1 %>
    <%== @pagy.info_tag %>
  <% else %>
    <%== pagy_nav @pagy if @pagy.last > 1 %>
    <%== pagy_info @pagy %>
  <% end %>
</div>
