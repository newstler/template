<%= content_for :title, resource_name_plural %>

<div class="max-w-3xl mx-auto">
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-3xl font-bold text-white"><%= resource_name_plural %></h1>
    <%= link_to resource.new_path, class: "inline-flex items-center gap-2 px-4 py-2 bg-dark-700 hover:bg-dark-600 text-dark-200 rounded-lg transition-colors" do %>
      New <%= resource_name %>
    <% end %>
  </div>

  <div class="filters mb-4 p-4 card-bg">
    <%= form_with url: resource.index_path, method: :get, class: "flex gap-3 items-end flex-wrap" do |f| %>
      <div>
        <%= f.label :q, t("madmin.common.search"), class: "block text-sm font-medium text-dark-300 mb-1" %>
        <%= f.search_field :q, value: params[:q], placeholder: t(".search_placeholder"), class: "form-input" %>
      </div>

      <div class="flex gap-2">
        <%= f.submit t("madmin.common.filter"), class: "btn btn-primary" %>
        <% if params[:q].present? %>
          <%= link_to t("madmin.common.clear"), resource.index_path, class: "btn btn-secondary" %>
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="table-scroll">
    <table>
      <thead>
        <tr>
          <th><%= sortable :email, t(".col_email") %></th>
          <th><%= sortable :created_at, t(".col_created") %></th>
        </tr>
      </thead>

      <tbody>
        <% @records.each do |record| %>
          <tr>
            <td>
              <%= link_to resource.show_path(record), class: "flex items-center gap-3" do %>
                <img src="https://www.gravatar.com/avatar/<%= Digest::MD5.hexdigest(record.email.downcase.strip) %>?s=32&d=mp" class="w-8 h-8 rounded-full" alt="">
                <span><%= record.email %></span>
              <% end %>
            </td>
            <td><%= l(record.created_at, format: :long) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="pagination">
    <% if @pagy.respond_to?(:series_nav) %>
      <%== @pagy.series_nav if @pagy.last > 1 %>
      <%== @pagy.info_tag %>
    <% else %>
      <%== pagy_nav @pagy if @pagy.last > 1 %>
      <%== pagy_info @pagy %>
    <% end %>
  </div>
</div>
