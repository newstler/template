<%# Modern dark sidebar navigation for Madmin - uses shared partials for consistent design %>

<%# Cache counters for sidebar badges %>
<%
  sidebar_counts = Rails.cache.fetch("madmin_sidebar_counts", expires_in: 2.minutes) do
    {
      teams: Team.count,
      users: User.count,
      memberships: Membership.count,
      articles: Article.count,
      conversations: Conversation.count,
      conversation_messages: ConversationMessage.count,
      chats: Chat.count,
      messages: Message.count,
      models: Model.count,
      tool_calls: ToolCall.count,
      noticed_events: Noticed::Event.count,
      noticed_notifications: Noticed::Notification.count,
      admins: Admin.count,
      languages: Language.count,
      blobs: ActiveStorage::Blob.count,
      attachments: ActiveStorage::Attachment.count,
      variants: ActiveStorage::VariantRecord.count
    }
  end
%>

<%# Sidebar %>
<aside data-sidebar-target="sidebar"
       class="fixed inset-y-0 left-0 z-40 w-64 bg-dark-850 transform -translate-x-full lg:translate-x-0 transition-transform duration-200 ease-in-out flex flex-col">

  <%# Logo/Brand %>
  <div class="flex items-center h-16 px-4">
    <%= link_to "/madmin", class: "flex items-center gap-3 text-white hover:opacity-80 transition-opacity" do %>
      <div class="w-8 h-8 bg-gradient-to-br from-purple-500 to-pink-600 rounded-lg flex items-center justify-center">
        <%= inline_svg "icons/shield.svg", class: "w-5 h-5 text-white" %>
      </div>
      <span class="font-semibold text-lg"><%= Madmin.site_name %> Admin</span>
    <% end %>
  </div>

  <%# Navigation %>
  <nav class="flex-1 overflow-y-auto py-4 px-3 flex flex-col sidebar-scroll">
    <%# Dashboard (top entry) %>
    <div class="space-y-1">
      <%= render "shared/sidebar_link", path: "/madmin", icon: "dashboard", label: "Dashboard" %>
      <%= link_to "/red", class: "flex items-center gap-3 px-3 py-2 text-sm text-dark-500 hover:text-dark-200 hover:bg-white/5 rounded-lg transition-colors", target: "_blank" do %>
        <%= inline_svg "icons/external-link.svg", class: "w-5 h-5 flex-shrink-0" %>
        <span>Error Dashboard</span>
      <% end %>
      <%= link_to main_app.root_path, class: "flex items-center gap-3 px-3 py-2 text-sm text-dark-500 hover:text-dark-200 hover:bg-white/5 rounded-lg transition-colors", target: "_blank" do %>
        <%= inline_svg "icons/external-link.svg", class: "w-5 h-5 flex-shrink-0" %>
        <span>Open Main App</span>
      <% end %>
    </div>

    <div class="my-4 border-t border-dark-700"></div>

    <%# Accounts %>
    <div class="mb-2 px-3">
      <span class="text-xs font-semibold text-dark-500 uppercase tracking-wider">Accounts</span>
    </div>
    <div class="space-y-1">
      <%= render "shared/sidebar_link", path: "/madmin/users", icon: "user", label: "Users", counter: sidebar_counts[:users] %>
      <%= render "shared/sidebar_link", path: "/madmin/teams", icon: "users", label: "Teams", counter: sidebar_counts[:teams] %>
      <%= render "shared/sidebar_link", path: "/madmin/memberships", icon: "users", label: "Memberships", counter: sidebar_counts[:memberships] %>
    </div>

    <div class="my-4 border-t border-dark-700"></div>

    <%# Billing %>
    <div class="mb-2 px-3">
      <span class="text-xs font-semibold text-dark-500 uppercase tracking-wider">Billing</span>
    </div>
    <div class="space-y-1">
      <%= render "shared/sidebar_link", path: "/madmin/prices", icon: "dollar", label: "Prices" %>
    </div>

    <div class="my-4 border-t border-dark-700"></div>

    <%# Content %>
    <div class="mb-2 px-3">
      <span class="text-xs font-semibold text-dark-500 uppercase tracking-wider">Content</span>
    </div>
    <div class="space-y-1">
      <%= render "shared/sidebar_link", path: "/madmin/articles", icon: "file", label: "Articles", counter: sidebar_counts[:articles] %>
      <%= render "shared/sidebar_link", path: "/madmin/conversations", icon: "chat", label: "Conversations", counter: sidebar_counts[:conversations] %>
      <%= render "shared/sidebar_link", path: "/madmin/conversation_messages", icon: "messages", label: "Conv. Messages", counter: sidebar_counts[:conversation_messages] %>
      <%= render "shared/sidebar_link", path: "/madmin/chats", icon: "chat", label: "Chats", counter: sidebar_counts[:chats] %>
      <%= render "shared/sidebar_link", path: "/madmin/messages", icon: "messages", label: "Messages", counter: sidebar_counts[:messages] %>
      <%= render "shared/sidebar_link", path: "/madmin/tool_calls", icon: "wrench", label: "Tool Calls", counter: sidebar_counts[:tool_calls] %>
    </div>

    <div class="my-4 border-t border-dark-700"></div>

    <%# Notifications %>
    <div class="mb-2 px-3">
      <span class="text-xs font-semibold text-dark-500 uppercase tracking-wider">Notifications</span>
    </div>
    <div class="space-y-1">
      <%= render "shared/sidebar_link", path: "/madmin/noticed_events", icon: "bell", label: "Events", counter: sidebar_counts[:noticed_events] %>
      <%= render "shared/sidebar_link", path: "/madmin/noticed_notifications", icon: "mail", label: "Notifications", counter: sidebar_counts[:noticed_notifications] %>
    </div>

    <%# Spacer to push Config to bottom %>
    <div class="flex-1"></div>

    <%# Config %>
    <div class="border-t border-dark-700 pt-4 mb-2 px-3">
      <span class="text-xs font-semibold text-dark-500 uppercase tracking-wider">Config</span>
    </div>

    <%# AI Section (collapsible) %>
    <div class="mt-1">
      <%= render "shared/sidebar_group", id: "ai", icon: "sparkles", label: "AI" do %>
        <%= render "shared/sidebar_link", path: "/madmin/ai_models", icon: "sparkles", label: "AI Models", nested: true %>
        <%= render "shared/sidebar_link", path: "/madmin/providers", icon: "cog", label: "Providers", nested: true %>
        <%= render "shared/sidebar_link", path: "/madmin/models", icon: "cube", label: "Models", nested: true, counter: sidebar_counts[:models] %>
      <% end %>
    </div>

    <%# Active Storage Section (collapsible) %>
    <div class="mt-1">
      <%= render "shared/sidebar_group", id: "storage", icon: "folder", label: "Active Storage" do %>
        <%= render "shared/sidebar_link", path: "/madmin/active_storage/blobs", icon: "file", label: "Blobs", nested: true, counter: sidebar_counts[:blobs] %>
        <%= render "shared/sidebar_link", path: "/madmin/active_storage/attachments", icon: "paperclip", label: "Attachments", nested: true, counter: sidebar_counts[:attachments] %>
        <%= render "shared/sidebar_link", path: "/madmin/active_storage/variant_records", icon: "image", label: "Variants", nested: true, counter: sidebar_counts[:variants] %>
      <% end %>
    </div>

    <%# Settings Section (collapsible) %>
    <div class="mt-1">
      <%= render "shared/sidebar_group", id: "settings", icon: "cog", label: "Settings" do %>
        <%= render "shared/sidebar_link", path: "/madmin/admins", icon: "shield", label: "Admins", nested: true, counter: sidebar_counts[:admins] %>
        <%= render "shared/sidebar_link", path: "/madmin/settings", icon: "key", label: "API Keys", nested: true %>
        <%= render "shared/sidebar_link", path: "/madmin/languages", icon: "globe", label: "Languages", nested: true, counter: sidebar_counts[:languages] %>
        <%= render "shared/sidebar_link", path: "/madmin/mail", icon: "mail", label: "Mail", nested: true %>
      <% end %>
    </div>

  </nav>

  <%# Admin section %>
  <div class="px-3 pb-4">
    <div class="border-t border-dark-700 pt-3 space-y-1">
      <% if defined?(current_admin) && current_admin %>
        <%= link_to "/madmin/admins/#{current_admin.id}", class: "flex items-center gap-3 px-3 py-2 text-sm text-dark-500 hover:text-dark-200 hover:bg-white/5 rounded-lg transition-colors" do %>
          <%= inline_svg "icons/shield.svg", class: "w-5 h-5 flex-shrink-0" %>
          <span class="truncate"><%= current_admin.email %></span>
        <% end %>
      <% end %>
      <%= button_to main_app.admins_session_path, method: :delete, class: "w-full flex items-center gap-3 px-3 py-2 text-sm text-dark-500 hover:text-dark-200 hover:bg-white/5 rounded-lg transition-colors", data: { turbo_confirm: "Sign out from admin panel?" } do %>
        <%= inline_svg "icons/sign-out.svg", class: "w-5 h-5 flex-shrink-0" %>
        <span>Sign Out</span>
      <% end %>
    </div>
  </div>
</aside>
