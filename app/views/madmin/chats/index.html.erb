<%= content_for :title, resource_name_plural %>

<header class="header">
  <h1><%= resource_name_plural %></h1>
  <% setting = Setting.instance %>
  <%= button_to main_app.toggle_ai_chats_madmin_chats_path, method: :patch, class: "inline-flex items-center gap-2 px-3 py-1.5 rounded-lg text-sm font-medium transition-colors #{setting.ai_chats_enabled? ? 'bg-emerald-500/15 text-emerald-400 hover:bg-emerald-500/25' : 'bg-dark-700 text-dark-400 hover:bg-dark-600'}" do %>
    <span class="w-2 h-2 rounded-full <%= setting.ai_chats_enabled? ? 'bg-emerald-400' : 'bg-dark-500' %>"></span>
    <%= t(".ai_chats") %> <%= setting.ai_chats_enabled? ? t("madmin.common.status_on") : t("madmin.common.status_off") %>
  <% end %>
</header>

<div class="filters mb-4 p-4 card-bg">
  <%= form_with url: resource.index_path, method: :get, class: "flex gap-3 items-end flex-wrap" do |f| %>
    <div>
      <%= f.label :q, t("madmin.common.search"), class: "block text-sm font-medium text-dark-300 mb-1" %>
      <%= f.search_field :q, value: params[:q], placeholder: t(".search_placeholder"), class: "form-input" %>
    </div>

    <div>
      <%= f.label :created_at_from, t("madmin.common.from"), class: "block text-sm font-medium text-dark-300 mb-1" %>
      <%= f.date_field :created_at_from, value: params[:created_at_from], class: "form-input" %>
    </div>

    <div>
      <%= f.label :created_at_to, t("madmin.common.to"), class: "block text-sm font-medium text-dark-300 mb-1" %>
      <%= f.date_field :created_at_to, value: params[:created_at_to], class: "form-input" %>
    </div>

    <div class="flex gap-2">
      <%= f.submit t("madmin.common.filter"), class: "btn btn-primary" %>
      <% if params[:q].present? || params[:created_at_from].present? || params[:created_at_to].present? %>
        <%= link_to t("madmin.common.clear"), resource.index_path, class: "btn btn-secondary" %>
      <% end %>
    </div>
  <% end %>
</div>

<div class="table-scroll">
  <table>
    <thead>
      <tr>
        <th><%= sortable :id, t(".col_first_message") %></th>
        <th><%= sortable :user_id, t(".col_user") %></th>
        <th><%= sortable :messages_count, t(".col_messages") %></th>
        <th><%= sortable :total_cost, t(".col_cost") %></th>
        <th><%= sortable :created_at, t(".col_created") %></th>
      </tr>
    </thead>

    <tbody>
      <% @records.each do |record| %>
        <tr>
          <td class="max-w-xs">
            <%= link_to resource.show_path(record), class: "block truncate" do %>
              <%= record.messages.min_by(&:created_at)&.content&.truncate(80) || t(".empty_chat") %>
            <% end %>
          </td>
          <td>
            <%= link_to "/madmin/users/#{record.user_id}", class: "hover:underline" do %>
              <%= record.user&.email %>
            <% end %>
          </td>
          <td><%= record.messages_count %></td>
          <td class="<%= (record.total_cost || 0) >= 0.10 ? 'text-red-400' : 'text-emerald-400' %>"><%= format_cost(record.total_cost || 0, precision: 4) %></td>
          <td><%= l(record.created_at, format: :long) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<div class="pagination">
  <% if @pagy.respond_to?(:series_nav) %>
    <%== @pagy.series_nav if @pagy.last > 1 %>
    <%== @pagy.info_tag %>
  <% else %>
    <%== pagy_nav @pagy if @pagy.last > 1 %>
    <%== pagy_info @pagy %>
  <% end %>
</div>
