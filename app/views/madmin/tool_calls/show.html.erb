<%= content_for :title, @record.name %>

<header class="header">
  <h1>
    <%= link_to resource.friendly_name.pluralize, resource.index_path %>
    /
    <%= @record.name %>
  </h1>
</header>

<div class="card-bg p-6 mb-6">
  <div class="flex items-start gap-5">
    <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-amber-500 to-orange-600 flex items-center justify-center shadow-lg shadow-amber-500/20">
      <%= inline_svg "icons/wrench.svg", class: "w-7 h-7 text-white" %>
    </div>
    <div class="flex-1">
      <h2 class="text-2xl font-bold text-dark-100"><%= @record.name %></h2>
      <div class="flex items-center gap-3 mt-2 text-sm text-dark-400">
        <span class="font-mono text-xs text-dark-500"><%= @record.tool_call_id %></span>
        <% if @record.message %>
          <span>&middot;</span>
          <span>in
            <%= link_to "/madmin/messages/#{@record.message_id}", class: "text-dark-200 hover:underline" do %>
              <%= @record.message.content&.truncate(50) || "Message ##{@record.message_id.to_s[0, 8]}" %>
            <% end %>
          </span>
        <% end %>
      </div>
      <p class="text-dark-500 text-sm mt-2">
        <%= @record.created_at.strftime("%-d %B %Y at %H:%M") %>
        <span class="text-dark-600">(<%= time_ago_in_words(@record.created_at) %> ago)</span>
      </p>
    </div>
  </div>
</div>

<div class="card-bg overflow-hidden mb-6">
  <div class="px-5 py-4 border-b border-dark-700">
    <h2 class="text-lg font-semibold text-dark-100">Details</h2>
  </div>
  <div class="table-scroll">
    <table>
      <tbody>
        <tr>
          <th class="label">Tool</th>
          <td class="font-medium text-dark-100"><%= @record.name %></td>
        </tr>
        <tr>
          <th class="label">Tool Call ID</th>
          <td class="font-mono text-sm text-dark-300"><%= @record.tool_call_id %></td>
        </tr>
        <% if @record.message %>
          <tr>
            <th class="label">Message</th>
            <td>
              <%= link_to "/madmin/messages/#{@record.message_id}", class: "hover:underline block max-w-md truncate" do %>
                <%= @record.message.content&.truncate(80) || "Message ##{@record.message_id.to_s[0, 8]}" %>
              <% end %>
            </td>
          </tr>
          <% if @record.message.chat %>
            <tr>
              <th class="label">Chat</th>
              <td>
                <%= link_to "/madmin/chats/#{@record.message.chat_id}", class: "hover:underline" do %>
                  Chat #<%= @record.message.chat_id.to_s[0, 8] %>
                <% end %>
              </td>
            </tr>
          <% end %>
        <% end %>
        <tr>
          <th class="label">Created</th>
          <td><%= @record.created_at.strftime("%-d %B %Y at %H:%M") %></td>
        </tr>
      </tbody>
    </table>
  </div>
</div>

<% if @record.arguments.present? %>
<div class="card-bg overflow-hidden mb-6">
  <div class="px-5 py-4 border-b border-dark-700">
    <h2 class="text-lg font-semibold text-dark-100">Arguments</h2>
  </div>
  <div class="p-5">
    <pre class="text-sm text-dark-200 bg-dark-950 rounded-lg p-4 overflow-x-auto"><%= JSON.pretty_generate(@record.arguments) rescue @record.arguments.inspect %></pre>
  </div>
</div>
<% end %>

<% if @record.respond_to?(:result) && @record.result.present? %>
<div class="card-bg overflow-hidden">
  <div class="px-5 py-4 border-b border-dark-700">
    <h2 class="text-lg font-semibold text-dark-100">Result</h2>
  </div>
  <div class="p-5">
    <pre class="text-sm text-dark-200 bg-dark-950 rounded-lg p-4 overflow-x-auto max-h-96"><%= JSON.pretty_generate(@record.result) rescue @record.result.to_s %></pre>
  </div>
</div>
<% end %>
