<%= content_for :title, "Notifications" %>

<header class="header">
  <h1>Notifications</h1>
</header>

<div class="filters mb-4 p-4 card-bg">
  <%= form_with url: resource.index_path, method: :get, class: "flex gap-3 items-end flex-wrap" do |f| %>
    <div>
      <%= f.label :type, class: "block text-sm font-medium text-dark-300 mb-1" %>
      <% types = Noticed::Notification.distinct.order(:type).pluck(:type).compact %>
      <%= f.select :type,
          options_for_select([["All types", ""]] + types.map { |t| [t.sub("Notifier::Notification", "").presence || t, t] }, params[:type]),
          {},
          class: "form-select" %>
    </div>

    <div>
      <%= f.label :status, class: "block text-sm font-medium text-dark-300 mb-1" %>
      <%= f.select :status,
          options_for_select([["All", ""], ["Read", "read"], ["Unread", "unread"]], params[:status]),
          {},
          class: "form-select" %>
    </div>

    <div>
      <%= f.label :created_at_from, "From:", class: "block text-sm font-medium text-dark-300 mb-1" %>
      <%= f.date_field :created_at_from, value: params[:created_at_from], class: "form-input" %>
    </div>

    <div>
      <%= f.label :created_at_to, "To:", class: "block text-sm font-medium text-dark-300 mb-1" %>
      <%= f.date_field :created_at_to, value: params[:created_at_to], class: "form-input" %>
    </div>

    <div class="flex gap-2">
      <%= f.submit "Filter", class: "btn btn-primary" %>
      <% if params[:type].present? || params[:status].present? || params[:created_at_from].present? || params[:created_at_to].present? %>
        <%= link_to "Clear", resource.index_path, class: "btn btn-secondary" %>
      <% end %>
    </div>
  <% end %>
</div>

<div class="table-scroll">
  <table>
    <thead>
      <tr>
        <th><%= sortable :type, "Notification" %></th>
        <th>Recipient</th>
        <th>Event</th>
        <th><%= sortable :read_at, "Status" %></th>
        <th><%= sortable :created_at, "Created" %></th>
      </tr>
    </thead>

    <tbody>
      <% @records.each do |record| %>
        <tr>
          <td>
            <%= link_to resource.show_path(record), class: "block" do %>
              <% type_label = record.type.to_s.sub("Notifier::Notification", "").presence || record.type.to_s %>
              <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-sm font-medium bg-purple-500/15 text-purple-400">
                <%= inline_svg "icons/bell.svg", class: "w-4 h-4 mr-1.5" %>
                <%= type_label %>
              </span>
            <% end %>
          </td>
          <td>
            <% if record.recipient_type == "User" %>
              <% recipient = record.recipient %>
              <% if recipient %>
                <%= link_to "/madmin/users/#{recipient.id}", class: "flex items-center gap-2" do %>
                  <img src="https://www.gravatar.com/avatar/<%= Digest::MD5.hexdigest(recipient.email.downcase.strip) %>?s=24&d=mp" class="w-6 h-6 rounded-full" alt="">
                  <span class="text-sm"><%= recipient.name.presence || recipient.email %></span>
                <% end %>
              <% else %>
                <span class="text-dark-500 text-sm">Deleted user</span>
              <% end %>
            <% else %>
              <span class="text-dark-300 text-sm"><%= record.recipient_type %> #<%= record.recipient_id.to_s[0, 8] %></span>
            <% end %>
          </td>
          <td>
            <% if record.event %>
              <%= link_to "/madmin/noticed_events/#{record.event_id}", class: "hover:underline text-sm text-dark-300" do %>
                <%= record.event.type.to_s.sub("Notifier", "") %>
              <% end %>
            <% else %>
              <span class="text-dark-500">-</span>
            <% end %>
          </td>
          <td>
            <% if record.read_at %>
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-emerald-500/15 text-emerald-400">
                Read
              </span>
            <% else %>
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-amber-500/15 text-amber-400">
                Unread
              </span>
            <% end %>
          </td>
          <td class="text-sm"><%= record.created_at.strftime("%-d %b %Y %H:%M") %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<div class="pagination">
  <% if @pagy.respond_to?(:series_nav) %>
    <%== @pagy.series_nav if @pagy.last > 1 %>
    <%== @pagy.info_tag %>
  <% else %>
    <%== pagy_nav @pagy if @pagy.last > 1 %>
    <%== pagy_info @pagy %>
  <% end %>
</div>
