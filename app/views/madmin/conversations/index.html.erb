<%= content_for :title, resource.friendly_name.pluralize %>

<header class="header">
  <h1><%= resource.friendly_name.pluralize %></h1>
  <div class="flex gap-2">
    <% setting = Setting.instance %>
    <%= button_to main_app.toggle_conversations_madmin_conversations_path, method: :patch, class: "inline-flex items-center gap-2 px-3 py-1.5 rounded-lg text-sm font-medium transition-colors #{setting.conversations_enabled? ? 'bg-emerald-500/15 text-emerald-400 hover:bg-emerald-500/25' : 'bg-dark-700 text-dark-400 hover:bg-dark-600'}" do %>
      <span class="w-2 h-2 rounded-full <%= setting.conversations_enabled? ? 'bg-emerald-400' : 'bg-dark-500' %>"></span>
      Conversations <%= setting.conversations_enabled? ? "On" : "Off" %>
    <% end %>
    <%= button_to main_app.toggle_moderation_madmin_conversations_path, method: :patch, class: "inline-flex items-center gap-2 px-3 py-1.5 rounded-lg text-sm font-medium transition-colors #{setting.conversation_moderation_enabled? ? 'bg-emerald-500/15 text-emerald-400 hover:bg-emerald-500/25' : 'bg-dark-700 text-dark-400 hover:bg-dark-600'}" do %>
      <span class="w-2 h-2 rounded-full <%= setting.conversation_moderation_enabled? ? 'bg-emerald-400' : 'bg-dark-500' %>"></span>
      Moderation <%= setting.conversation_moderation_enabled? ? "On" : "Off" %>
    <% end %>
  </div>
</header>

<div class="filters mb-4 p-4 card-bg">
  <%= form_with url: resource.index_path, method: :get, class: "flex gap-3 items-end flex-wrap" do |f| %>
    <div>
      <%= f.label :q, "Search", class: "block text-sm font-medium text-dark-300 mb-1" %>
      <%= f.search_field :q, value: params[:q], placeholder: "Search by title...", class: "form-input" %>
    </div>

    <div>
      <%= f.label :created_at_from, "From:", class: "block text-sm font-medium text-dark-300 mb-1" %>
      <%= f.date_field :created_at_from, value: params[:created_at_from], class: "form-input" %>
    </div>

    <div>
      <%= f.label :created_at_to, "To:", class: "block text-sm font-medium text-dark-300 mb-1" %>
      <%= f.date_field :created_at_to, value: params[:created_at_to], class: "form-input" %>
    </div>

    <div class="flex gap-2">
      <%= f.submit "Filter", class: "btn btn-primary" %>
      <% if params[:q].present? || params[:created_at_from].present? || params[:created_at_to].present? %>
        <%= link_to "Clear", resource.index_path, class: "btn btn-secondary" %>
      <% end %>
    </div>
  <% end %>
</div>

<div class="table-scroll">
  <table>
    <thead>
      <tr>
        <th><%= sortable :title, "Conversation" %></th>
        <th>Teams</th>
        <th>Participants</th>
        <th>Messages</th>
        <th>Subject</th>
        <th><%= sortable :updated_at, "Last Activity" %></th>
        <th><%= sortable :created_at, "Created" %></th>
      </tr>
    </thead>

    <tbody>
      <% @records.each do |record| %>
        <tr>
          <td class="max-w-xs">
            <%= link_to resource.show_path(record), class: "block" do %>
              <div class="font-medium truncate"><%= record.title.presence || "Conversation #{record.id[0, 8]}..." %></div>
            <% end %>
          </td>
          <td>
            <div class="flex flex-wrap items-center gap-1.5">
              <% record.teams.each do |team| %>
                <%= link_to "/madmin/teams/#{team.slug}", class: "inline-flex items-center gap-1.5 hover:underline" do %>
                  <div class="w-5 h-5 rounded bg-dark-600 flex items-center justify-center text-[10px] font-bold text-dark-300">
                    <%= team.name.first(2).upcase %>
                  </div>
                  <span class="font-medium text-sm"><%= team.name %></span>
                <% end %>
              <% end %>
            </div>
          </td>
          <td>
            <div class="flex -space-x-2">
              <% record.conversation_participants.first(4).each do |cp| %>
                <img src="https://www.gravatar.com/avatar/<%= Digest::MD5.hexdigest(cp.user.email.downcase.strip) %>?s=24&d=mp"
                     class="w-6 h-6 rounded-full ring-2 ring-dark-800"
                     title="<%= cp.user.name.presence || cp.user.email %>"
                     alt="">
              <% end %>
              <% if record.conversation_participants.size > 4 %>
                <span class="w-6 h-6 rounded-full ring-2 ring-dark-800 bg-dark-600 flex items-center justify-center text-[10px] text-dark-300">
                  +<%= record.conversation_participants.size - 4 %>
                </span>
              <% end %>
            </div>
          </td>
          <td><%= record.conversation_messages.size %></td>
          <td>
            <% if record.subject_type.present? %>
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-dark-600 text-dark-300">
                <%= record.subject_type %>
              </span>
            <% else %>
              <span class="text-dark-500">-</span>
            <% end %>
          </td>
          <td class="text-sm"><%= record.updated_at.strftime("%-d %b %Y %H:%M") %></td>
          <td class="text-sm"><%= record.created_at.strftime("%-d %b %Y") %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<div class="pagination">
  <% if @pagy.respond_to?(:series_nav) %>
    <%== @pagy.series_nav if @pagy.last > 1 %>
    <%== @pagy.info_tag %>
  <% else %>
    <%== pagy_nav @pagy if @pagy.last > 1 %>
    <%== pagy_info @pagy %>
  <% end %>
</div>
