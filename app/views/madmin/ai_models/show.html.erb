<% active_tab = params[:tab] == "available" ? 1 : 0 %>

<div class="max-w-3xl mx-auto">
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-white"><%= t(".heading") %></h1>
  </div>

  <div data-controller="tabs" data-tabs-active-class="border-accent-500 text-dark-100" data-tabs-inactive-class="border-transparent text-dark-400 hover:text-dark-200">
    <div class="flex gap-0 border-b border-dark-700 mb-6">
      <button data-tabs-target="tab" data-action="click->tabs#select" data-index="0"
              class="px-5 py-3 text-sm font-medium border-b-2 transition-colors -mb-px <%= active_tab == 0 ? 'border-accent-500 text-dark-100' : 'border-transparent text-dark-400 hover:text-dark-200' %>">
        <%= t(".tab_used") %>
      </button>
      <button data-tabs-target="tab" data-action="click->tabs#select" data-index="1"
              class="px-5 py-3 text-sm font-medium border-b-2 transition-colors -mb-px <%= active_tab == 1 ? 'border-accent-500 text-dark-100' : 'border-transparent text-dark-400 hover:text-dark-200' %>">
        <%= t(".tab_available") %>
      </button>
    </div>

    <%# Used Tab — inline editing with autosave %>
    <div data-tabs-target="panel" class="<%= 'hidden' if active_tab != 0 %>">
      <% if @available_models.empty? %>
        <div class="card-bg p-6 text-center">
          <div class="text-dark-400 mb-2"><%= t(".no_models") %></div>
          <p class="text-sm text-dark-500 mb-4"><%= t(".no_models_hint") %></p>
        </div>
      <% else %>
        <%= form_with model: @setting, url: main_app.madmin_ai_models_path, method: :patch, data: { controller: "autosave" }, class: "space-y-6" do |form| %>
          <span data-autosave-target="status" class="hidden fixed top-4 right-4 z-50 px-3 py-1.5 bg-dark-700 text-dark-200 text-sm rounded-lg shadow-lg"></span>

          <% model_options = [["— Select model —", ""]] + @available_models.map { |name, model_id| ["#{name} (#{model_id})", model_id] } %>

          <%# Chat Model %>
          <div class="card-bg p-6">
            <h2 class="text-xl font-semibold text-dark-100 mb-2"><%= t(".chat_heading") %></h2>
            <p class="text-sm text-dark-500 mb-4"><%= t(".chat_description") %></p>
            <div>
              <%= form.select :default_model,
                options_for_select(model_options, @setting.default_model),
                {},
                data: { action: "change->autosave#save" },
                class: "w-full px-4 py-3 border border-dark-600 bg-dark-800 text-dark-100 rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 focus:outline-none transition-all text-sm" %>
            </div>
          </div>

          <%# Translation Model %>
          <div class="card-bg p-6">
            <h2 class="text-xl font-semibold text-dark-100 mb-2"><%= t(".translation_heading") %></h2>
            <p class="text-sm text-dark-500 mb-4"><%= t(".translation_description") %></p>
            <div>
              <%= form.select :translation_model,
                options_for_select(model_options, @setting.translation_model),
                {},
                data: { action: "change->autosave#save" },
                class: "w-full px-4 py-3 border border-dark-600 bg-dark-800 text-dark-100 rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 focus:outline-none transition-all text-sm" %>
            </div>
          </div>

          <%# Moderation Model %>
          <div class="card-bg p-6">
            <h2 class="text-xl font-semibold text-dark-100 mb-2"><%= t(".moderation_heading") %></h2>
            <p class="text-sm text-dark-500 mb-4"><%= t(".moderation_description") %></p>
            <div>
              <%= form.select :moderation_model,
                options_for_select(model_options, @setting.moderation_model),
                {},
                data: { action: "change->autosave#save" },
                class: "w-full px-4 py-3 border border-dark-600 bg-dark-800 text-dark-100 rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 focus:outline-none transition-all text-sm" %>
            </div>
          </div>

          <%# Embedding Model %>
          <% embedding_options = [["— Select model —", ""]] + @embedding_models.map { |model_id| [model_id, model_id] } %>
          <div class="card-bg p-6">
            <div class="flex items-center justify-between mb-2">
              <h2 class="text-xl font-semibold text-dark-100"><%= t(".embedding_heading") %></h2>
              <%= link_to t(".rebuild_embeddings"), main_app.rebuild_embeddings_madmin_ai_models_path, data: { turbo_method: :post, turbo_confirm: t(".rebuild_embeddings_confirm") }, class: "inline-flex items-center gap-2 px-3 py-1.5 text-sm font-medium bg-dark-700 hover:bg-dark-600 text-dark-200 rounded-lg transition-colors" %>
            </div>
            <p class="text-sm text-dark-500 mb-4"><%= t(".embedding_description") %></p>
            <div>
              <%= form.select :embedding_model,
                options_for_select(embedding_options, @setting.embedding_model),
                {},
                data: { action: "change->autosave#save" },
                class: "w-full px-4 py-3 border border-dark-600 bg-dark-800 text-dark-100 rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 focus:outline-none transition-all text-sm" %>
            </div>
          </div>
        <% end %>
      <% end %>
    </div>

    <%# Available Tab — models table %>
    <div data-tabs-target="panel" class="<%= 'hidden' if active_tab != 1 %>">
      <div class="flex items-center justify-between mb-4">
        <div class="flex gap-3 items-end flex-wrap">
          <%= form_with url: main_app.madmin_ai_models_path, method: :get, class: "flex gap-3 items-end flex-wrap" do |f| %>
            <%= f.hidden_field :tab, value: "available" %>
            <div>
              <%= f.search_field :q, value: params[:q], placeholder: "Search models...", class: "form-input" %>
            </div>
            <div>
              <%= f.select :provider,
                options_for_select([["All providers", ""]] + @providers_list.map { |p| [p.titleize, p] }, params[:provider]),
                {},
                class: "form-select" %>
            </div>
            <div class="flex gap-2">
              <%= f.submit "Filter", class: "btn btn-primary" %>
              <% if params[:q].present? || params[:provider].present? %>
                <%= link_to "Clear", main_app.madmin_ai_models_path(tab: "available"), class: "btn btn-secondary" %>
              <% end %>
            </div>
          <% end %>
        </div>
        <%= button_to t(".refresh_models"),
            main_app.refresh_all_madmin_ai_models_path,
            method: :post,
            class: "btn btn-primary",
            data: { turbo_confirm: "Refresh all models from RubyLLM?" } %>
      </div>

      <div class="table-scroll">
        <table>
          <thead>
            <tr>
              <th>Provider</th>
              <th>Family</th>
              <th>Name</th>
              <th>Chats</th>
              <th>Total Cost</th>
            </tr>
          </thead>
          <tbody>
            <% @models.each do |model| %>
              <tr>
                <td>
                  <span class="px-2 py-1 text-xs font-medium rounded bg-dark-600 text-dark-200">
                    <%= model.provider %>
                  </span>
                </td>
                <td><%= model.family %></td>
                <td>
                  <%= link_to "/madmin/models/#{model.id}", class: "font-medium hover:underline" do %>
                    <%= model.name %>
                  <% end %>
                </td>
                <td><%= model.chats_count %></td>
                <td class="<%= (model.total_cost || 0) >= 1.0 ? 'text-red-400' : 'text-emerald-400' %>"><%= model.formatted_total_cost || "-" %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <div class="pagination">
        <% if @pagy.respond_to?(:series_nav) %>
          <%== @pagy.series_nav if @pagy.last > 1 %>
          <%== @pagy.info_tag %>
        <% else %>
          <%== pagy_nav @pagy if @pagy.last > 1 %>
          <%== pagy_info @pagy %>
        <% end %>
      </div>
    </div>
  </div>
</div>
