<div class="max-w-3xl mx-auto">
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-dark-50"><%= t(".heading") %></h1>
  </div>

  <% if @available_models.empty? %>
    <div class="bg-dark-900 py-8 px-6 rounded-xl border border-dark-700 text-center">
      <div class="text-dark-400 mb-2"><%= t(".no_models") %></div>
      <p class="text-sm text-dark-500 mb-4"><%= t(".no_models_hint") %></p>
      <%= link_to t(".sync_models"), "/madmin/models", class: "inline-flex items-center gap-2 px-4 py-2 bg-dark-700 hover:bg-dark-600 text-dark-200 rounded-lg transition-colors" %>
    </div>
  <% else %>
    <%= form_with model: @setting, url: main_app.madmin_ai_models_path, method: :patch, class: "space-y-6" do |form| %>
      <%# Default Chat Model %>
      <div class="bg-dark-900 py-8 px-6 rounded-xl border border-dark-700">
        <h2 class="text-xl font-semibold text-dark-100 mb-2"><%= t(".chat_heading") %></h2>
        <p class="text-sm text-dark-500 mb-6"><%= t(".chat_description") %></p>
        <div>
          <%= form.label :default_model, t(".default_model"), class: "block text-sm font-medium text-dark-200 mb-2" %>
          <%= form.select :default_model,
            options_for_select(
              [["— Select model —", ""]] + @available_models.map { |name, model_id| ["#{name} (#{model_id})", model_id] },
              @setting.default_model
            ),
            {},
            class: "w-full px-4 py-3 border border-dark-600 bg-dark-800 text-dark-100 rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 focus:outline-none transition-all text-sm" %>
          <p class="mt-1 text-xs text-dark-500"><%= t(".default_model_hint") %></p>
        </div>
      </div>

      <%# Translation Model %>
      <div class="bg-dark-900 py-8 px-6 rounded-xl border border-dark-700">
        <h2 class="text-xl font-semibold text-dark-100 mb-2"><%= t(".translation_heading") %></h2>
        <p class="text-sm text-dark-500 mb-6"><%= t(".translation_description") %></p>
        <div>
          <%= form.label :translation_model, t(".translation_model"), class: "block text-sm font-medium text-dark-200 mb-2" %>
          <%= form.select :translation_model,
            options_for_select(
              [["— Select model —", ""]] + @available_models.map { |name, model_id| ["#{name} (#{model_id})", model_id] },
              @setting.translation_model
            ),
            {},
            class: "w-full px-4 py-3 border border-dark-600 bg-dark-800 text-dark-100 rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 focus:outline-none transition-all text-sm" %>
          <p class="mt-1 text-xs text-dark-500"><%= t(".translation_model_hint") %></p>
        </div>
      </div>

      <%# Moderation Model %>
      <div class="bg-dark-900 py-8 px-6 rounded-xl border border-dark-700">
        <h2 class="text-xl font-semibold text-dark-100 mb-2"><%= t(".moderation_heading") %></h2>
        <p class="text-sm text-dark-500 mb-6"><%= t(".moderation_description") %></p>
        <div>
          <%= form.label :moderation_model, t(".moderation_model"), class: "block text-sm font-medium text-dark-200 mb-2" %>
          <%= form.select :moderation_model,
            options_for_select(
              [ [ "— Select model —", "" ] ] + @available_models.map { |name, model_id| [ "#{name} (#{model_id})", model_id ] },
              @setting.moderation_model
            ),
            {},
            class: "w-full px-4 py-3 border border-dark-600 bg-dark-800 text-dark-100 rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 focus:outline-none transition-all text-sm" %>
          <p class="mt-1 text-xs text-dark-500"><%= t(".moderation_model_hint") %></p>
        </div>
      </div>

      <%# Conversations %>
      <div class="bg-dark-900 py-8 px-6 rounded-xl border border-dark-700">
        <h2 class="text-xl font-semibold text-dark-100 mb-2"><%= t(".conversations_heading") %></h2>
        <p class="text-sm text-dark-500 mb-6"><%= t(".conversations_description") %></p>
        <div>
          <%= form.label :conversation_digest_window_minutes, t(".conversation_digest_window_minutes"), class: "block text-sm font-medium text-dark-200 mb-2" %>
          <%= form.number_field :conversation_digest_window_minutes,
            min: 1,
            class: "w-full px-4 py-3 border border-dark-600 bg-dark-800 text-dark-100 rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 focus:outline-none transition-all text-sm font-mono" %>
          <p class="mt-1 text-xs text-dark-500"><%= t(".conversation_digest_window_minutes_hint") %></p>
        </div>
      </div>

      <%# Currency & Country %>
      <div class="bg-dark-900 py-8 px-6 rounded-xl border border-dark-700">
        <h2 class="text-xl font-semibold text-dark-100 mb-2"><%= t(".currency_country_heading") %></h2>
        <p class="text-sm text-dark-500 mb-6"><%= t(".currency_country_description") %></p>

        <div class="space-y-6">
          <div>
            <%= form.label :default_currency, t(".default_currency"), class: "block text-sm font-medium text-dark-200 mb-2" %>
            <%= form.text_field :default_currency,
              class: "w-full px-4 py-3 border border-dark-600 bg-dark-800 text-dark-100 rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 focus:outline-none transition-all text-sm font-mono" %>
            <p class="mt-1 text-xs text-dark-500"><%= t(".default_currency_hint") %></p>
          </div>

          <div>
            <%= form.label :default_country_code, t(".default_country_code"), class: "block text-sm font-medium text-dark-200 mb-2" %>
            <%= form.text_field :default_country_code,
              class: "w-full px-4 py-3 border border-dark-600 bg-dark-800 text-dark-100 rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 focus:outline-none transition-all text-sm font-mono" %>
            <p class="mt-1 text-xs text-dark-500"><%= t(".default_country_code_hint") %></p>
          </div>

          <div>
            <%= form.label :currencylayer_api_key, t(".currencylayer_api_key"), class: "block text-sm font-medium text-dark-200 mb-2" %>
            <%= form.password_field :currencylayer_api_key,
              value: @setting.currencylayer_api_key,
              class: "w-full px-4 py-3 border border-dark-600 bg-dark-800 text-dark-100 rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 focus:outline-none transition-all text-sm font-mono" %>
            <p class="mt-1 text-xs text-dark-500"><%= t(".currencylayer_api_key_hint") %></p>
          </div>
        </div>
      </div>

      <%# Search %>
      <div class="bg-dark-900 py-8 px-6 rounded-xl border border-dark-700">
        <h2 class="text-xl font-semibold text-dark-100 mb-2"><%= t(".search_heading") %></h2>
        <p class="text-sm text-dark-500 mb-6"><%= t(".search_description") %></p>
        <div>
          <%= form.label :search_tokenizer, t(".search_tokenizer"), class: "block text-sm font-medium text-dark-200 mb-2" %>
          <%= form.text_field :search_tokenizer,
            class: "w-full px-4 py-3 border border-dark-600 bg-dark-800 text-dark-100 rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 focus:outline-none transition-all text-sm font-mono" %>
          <p class="mt-1 text-xs text-dark-500"><%= t(".search_tokenizer_hint") %></p>
        </div>
      </div>

      <%# Embeddings %>
      <div class="bg-dark-900 py-8 px-6 rounded-xl border border-dark-700">
        <h2 class="text-xl font-semibold text-dark-100 mb-2"><%= t(".embedding_heading") %></h2>
        <p class="text-sm text-dark-500 mb-6"><%= t(".embedding_description") %></p>

        <div class="space-y-6">
          <div>
            <%= form.label :embedding_model, t(".embedding_model"), class: "block text-sm font-medium text-dark-200 mb-2" %>
            <%= form.text_field :embedding_model,
              class: "w-full px-4 py-3 border border-dark-600 bg-dark-800 text-dark-100 rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 focus:outline-none transition-all text-sm font-mono" %>
            <p class="mt-1 text-xs text-dark-500"><%= t(".embedding_model_hint") %></p>
          </div>

          <div>
            <%= form.label :rrf_k, t(".rrf_k"), class: "block text-sm font-medium text-dark-200 mb-2" %>
            <%= form.number_field :rrf_k,
              min: 1,
              class: "w-full px-4 py-3 border border-dark-600 bg-dark-800 text-dark-100 rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 focus:outline-none transition-all text-sm font-mono" %>
            <p class="mt-1 text-xs text-dark-500"><%= t(".rrf_k_hint") %></p>
          </div>
        </div>
      </div>

      <%# Actions %>
      <div class="flex items-center gap-4">
        <%= form.submit t(".save"),
          class: "bg-gradient-to-r from-blue-600 to-blue-700 hover:from-blue-700 hover:to-blue-800 text-white py-3 px-6 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500/50 font-medium transition-all cursor-pointer shadow-lg shadow-blue-500/25" %>
        <%= link_to t(".cancel"), main_app.madmin_ai_models_path, class: "text-dark-400 hover:text-dark-300 transition-colors" %>
      </div>
    <% end %>
  <% end %>
</div>
