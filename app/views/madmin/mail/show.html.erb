<div class="max-w-3xl mx-auto">
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-white"><%= t(".heading") %></h1>
  </div>

  <%= form_with model: @setting, url: main_app.madmin_mail_path, method: :patch, data: { controller: "autosave" }, class: "space-y-6" do |form| %>
    <span data-autosave-target="status" class="hidden fixed top-4 right-4 z-50 px-3 py-1.5 bg-dark-700 text-dark-200 text-sm rounded-lg shadow-lg"></span>

    <%# General %>
    <div class="card-bg p-6">
      <h2 class="text-xl font-semibold text-dark-100 mb-4"><%= t(".general") %></h2>
      <div>
        <%= form.label :mail_from, t(".mail_from"), class: "block text-sm font-medium text-dark-200 mb-2" %>
        <%= form.email_field :mail_from,
          placeholder: "noreply@example.com",
          data: { action: "change->autosave#save" },
          class: "w-full px-4 py-3 border border-dark-600 bg-dark-800 text-dark-100 rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 focus:outline-none transition-all placeholder-dark-500 text-sm" %>
      </div>
    </div>

    <%# SMTP %>
    <div class="card-bg p-6">
      <h2 class="text-xl font-semibold text-dark-100 mb-4"><%= t(".smtp") %></h2>
      <div class="space-y-4">
        <div>
          <%= form.label :smtp_address, t(".smtp_address"), class: "block text-sm font-medium text-dark-200 mb-2" %>
          <%= form.text_field :smtp_address,
            placeholder: "smtp.postmarkapp.com",
            data: { action: "change->autosave#save" },
            class: "w-full px-4 py-3 border border-dark-600 bg-dark-800 text-dark-100 rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 focus:outline-none transition-all placeholder-dark-500 text-sm" %>
        </div>
        <div>
          <%= form.label :smtp_username, t(".smtp_username"), class: "block text-sm font-medium text-dark-200 mb-2" %>
          <%= form.text_field :smtp_username,
            placeholder: t(".smtp_username_placeholder"),
            data: { action: "change->autosave#save" },
            class: "w-full px-4 py-3 border border-dark-600 bg-dark-800 text-dark-100 rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 focus:outline-none transition-all placeholder-dark-500 text-sm" %>
        </div>
        <div>
          <%= form.label :smtp_password, t(".smtp_password"), class: "block text-sm font-medium text-dark-200 mb-2" %>
          <%= form.password_field :smtp_password,
            value: @setting.smtp_password,
            placeholder: t(".key_placeholder"),
            data: { action: "change->autosave#save" },
            class: "w-full px-4 py-3 border border-dark-600 bg-dark-800 text-dark-100 rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 focus:outline-none transition-all placeholder-dark-500 font-mono text-sm" %>
        </div>
      </div>
    </div>

    <%# Conversations %>
    <div class="card-bg p-6">
      <h2 class="text-xl font-semibold text-dark-100 mb-2"><%= t(".conversations_heading") %></h2>
      <p class="text-sm text-dark-500 mb-4"><%= t(".conversations_description") %></p>
      <div>
        <%= form.label :conversation_digest_window_minutes, t(".conversation_digest_window_minutes"), class: "block text-sm font-medium text-dark-200 mb-2" %>
        <%= form.number_field :conversation_digest_window_minutes,
          min: 1,
          data: { action: "change->autosave#save" },
          class: "w-full px-4 py-3 border border-dark-600 bg-dark-800 text-dark-100 rounded-lg focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 focus:outline-none transition-all text-sm font-mono" %>
        <p class="mt-1 text-xs text-dark-500"><%= t(".conversation_digest_window_minutes_hint") %></p>
      </div>
    </div>
  <% end %>
</div>
